{
  "name": "ex8_deployment",
  "version": "1.0.0",
  "description": "Exercise 8, CI/CD and testing",
  "main": "index.js",
  "c8": {
    "exclude": [
      "src/.internal/**",
      "coverage/**"
    ],
    "reporter": [
      "text",
      "lcov"
    ],
    "all": true
  },
  "scripts": {
