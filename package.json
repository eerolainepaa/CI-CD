  },
  "author": "Eero Lainepää",
  "license": "MIT",
  "devDependencies": {
    "c8": "^11.0.0",
    "chai": "^5.2.0",
    "coveralls": "^3.1.1",
    "globals": "^17.4.0",
    "mocha": "^11.0.0",
    "supertest": "^7.0.0"
  },
  "directories": {
    "test": "test"
  }
}
